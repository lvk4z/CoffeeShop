# ── Required in production ────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Set to False in production
DEBUG=True

# PostgreSQL connection string
# Docker Compose: use the value below
DATABASE_URL=postgresql://copijesz:copijesz@db:5432/copijesz

# Your domain (used by nginx + ALLOWED_HOSTS)
# Example: copijesz.com
EXTRA_ALLOWED_HOSTS=copijesz.com,www.copijesz.com
